# ================== SMTP ==================
# Пример для Яндекс 360 для бизнеса на домене pravo.shop:
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=lead@pravo.shop
# Пароль приложения (НЕ основной пароль от почты!)
# Создаётся в id.yandex.ru → Безопасность → Пароли приложений → Почта
SMTP_PASS=xxxxxxxxxxxxxxxx

# Пример для Mail.ru для бизнеса:
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_USER=lead@pravo.shop
# SMTP_PASS=<пароль для внешних приложений>

# ================== АДРЕСА ==================
# Куда шлём заявки
MAIL_TO=lead@pravo.shop
# От кого (должен быть на том же домене, иначе письма пойдут в спам)
MAIL_FROM=lead@pravo.shop
MAIL_FROM_NAME=Сайт ЛИКВИДАТОР

# ================== CORS ==================
# "same-origin" если API и сайт на одном домене (рекомендуется).
# Иначе укажи боевой URL фронта, например https://pravo.shop
ALLOWED_ORIGIN=same-origin

# ================== АНТИСПАМ ==================
# Макс. заявок с одного IP в час
RATE_LIMIT_PER_HOUR=3

# ================== СЕРВЕР ==================
# Timeweb Cloud Apps сам подставит PORT
PORT=8000

# ================== PREVIEW (черновики SEO-конвейера) ==================
# Если задано - открывается роут /preview с Basic Auth (просмотр drafts/{slug}/article.html).
# Все ответы /preview получают X-Robots-Tag: noindex,nofollow + meta noindex в HTML.
# Если не задано - роут /preview возвращает 503.
PREVIEW_USER=likvidator
PREVIEW_PASSWORD=замени_на_надёжный_пароль

# ================== TELEGRAM-БОТ для ревью статей ==================
# ОБЯЗАТЕЛЬНЫЕ:

# Токен бота от @BotFather (после /newbot)
TG_BOT_TOKEN=123456789:AAH...replace_me...

# chat_id заказчика (узнать у @userinfobot - пишет число).
# Если несколько получателей - через запятую: 12345,67890
TG_ALLOWED_CHAT_IDS=123456789

# ОПЦИОНАЛЬНЫЕ:

# Groq API ключ - для распознавания голосовых сообщений (Whisper, бесплатно).
# Регистрация: https://console.groq.com/keys
# Если не задан - бот игнорирует голосовые, можно писать только текстом.
GROQ_API_KEY=gsk_...replace_me...

# text.ru API ключ - для проверки уникальности (свободные 1000 проверок/мес).
# Регистрация: https://text.ru/api-check
# Если не задан - метрика уникальности не показывается.
TEXTRU_USER_KEY=

# Публичный адрес сайта для ссылок в Telegram. По умолчанию pravo.shop.
PUBLIC_BASE_URL=https://pravo.shop

# Интервал сканирования папки drafts/ в секундах (по умолчанию 60).
BOT_WATCH_INTERVAL=60

# ================== Claude Code (для применения правок ботом и scheduler'а) ==================
# На сервере (Cloud Apps) - через CLAUDE_CODE_OAUTH_TOKEN ниже.
# Локально - через `claude /login` (токен в ~/.claude.json создаётся сам).
#
# CLAUDE_CODE_OAUTH_TOKEN получаем командой `claude setup-token` локально один раз.
# Долгоживущий токен (~год), привязан к подписке. Без него articles_scheduler
# не сможет вызывать /write-article на сервере.
CLAUDE_CODE_OAUTH_TOKEN=

# ================== ARTICLES SCHEDULER (Этап 2) ==================
# APScheduler-таймер, запускающий /write-article каждые N минут.
# Безопасный дефолт: false. Включать ТОЛЬКО на сервере и только когда всё проверено.
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_MINUTES=144
SCHEDULER_TZ=Europe/Moscow
ARTICLES_PER_DAY=1
ROTATION_ORDER=fiz,yur,vzysk,news
ARTICLE_TIMEOUT_SEC=2400

# ================== GIT PUSH (для scheduler и publisher) ==================
# Используем SSH Deploy Key (не PAT, бессрочный).
# Локально - не нужно, push с сервера.
# На сервере (Cloud Apps) положи приватный ключ целиком (включая
# -----BEGIN/END OPENSSH PRIVATE KEY-----) в эту переменную:
SSH_PRIVATE_KEY=
GITHUB_REPO=triyul22/liquidator
GITHUB_BRANCH=main
GIT_AUTHOR_NAME=Liquidator Scheduler
GIT_AUTHOR_EMAIL=scheduler@pravo.shop

# ================== CLOUDINARY (Этап 3, обложки статей) ==================
# Регистрация бесплатно: https://cloudinary.com (без банковской карты).
# 25 GB хранения + 25 GB трафика/мес бесплатно.
# В Dashboard видны три значения - подставь сюда:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=articles

# ================== FAL.AI (генерация обложек) ==================
# Регистрация: https://fal.ai (можно через GitHub).
# Пополнение: минимум $5 для старта (~150-200 обложек по $0.03).
# Ключ создаётся в Dashboard → API Keys.
FAL_KEY=
# Модель по умолчанию: nano-banana-2 (Google Gemini-based) - 4K, отлично с
# отсутствием псевдо-кириллицы. Принимает aspect_ratio + resolution.
# Альтернатива: fal-ai/bytedance/seedream/v4/text-to-image (старая, малое разрешение).
FAL_MODEL=fal-ai/nano-banana-2
FAL_RESOLUTION=4K
FAL_ASPECT_RATIO=16:9
FAL_TIMEOUT_SEC=120
# Веб-трансформация Cloudinary - Cloudinary хранит мастер-файл 4K, а на сайт
# отдаёт через URL-трансформацию: автоматический формат (WebP/AVIF/JPEG),
# автоматическое качество, ширина 1920px. Меняй на f_auto,q_auto,w_1200 если
# нужна меньшая ширина.
CLOUDINARY_WEB_TRANSFORMATION=f_auto,q_auto,w_1920
# Если задан - используется как fallback при ошибке генерации (например,
# Cloudinary URL заранее загруженной заглушки):
IMAGE_GEN_DEFAULT_COVER_URL=

# ================== YANDEX WORDSTAT (Этап 4, проверка частотности) ==================
# Используем Yandex Cloud AI Studio Search API v2 - Wordstat бесплатный.
# Регистрация: https://console.cloud.yandex.ru
# 1) Создать сервисный аккаунт с ролью editor для текущей папки
# 2) Создать API-ключ для этого аккаунта
# 3) Узнать folderId в настройках папки (короткая строка b1g...)
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_FOLDER_ID=
# Регион geoId (225 = Россия, 213 = Москва, см. https://yandex.ru/dev/direct/doc/dg/concepts/geo.html)
WORDSTAT_REGION_CODE=225
# Срок жизни кэша частотности (Wordstat обновляется раз в месяц - чаще не нужно)
WORDSTAT_CACHE_TTL_DAYS=30

# ================== INDEXNOW (опционально) ==================
# Бесплатное оповещение Яндекс/Bing о новых статьях.
# Любая случайная строка длиной 8-128 символов. Положи её также в файл
# /pravo.shop/<INDEXNOW_KEY>.txt (содержимое = эта же строка) - так Яндекс
# проверит, что ты реально владеешь сайтом. Если ключа нет - просто не пингаем.
INDEXNOW_KEY=
INDEXNOW_HOST=pravo.shop
