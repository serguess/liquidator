.env
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.DS_Store
Thumbs.db

# локальная БД эмбеддингов и кэши:
# - SQLite БД эмбеддингов НЕ коммитим (большой бинарник, генерируется локально)
# - JSON-кэши фактов и ключевиков коммитим: нужны на сервере для агентов и актуализации
data/*
!data/README.md
!data/research_cache.json
!data/clusters.json
!data/keywords.json
!data/queue.json
# Сохраняем историю работы между редеплоями Cloud Apps:
!data/scheduler_log.json
!data/bot_state.json
!data/wordstat_cache.json
!data/git_errors.log
!data/published_index.json
# Флаг что одноразовая миграция bootstrap-sentinel выполнена.
# Коммитится чтобы не повторяться при каждом редеплое и не глушить
# уведомления о новых статьях от scheduler'а.
!data/.bootstrap_sentinel_done
# Pipeline-логи в drafts/{slug}/_pipeline.log.json — попадают в репо
# автоматически вместе с папкой drafts/{slug}/.
*.sqlite
*.sqlite-journal

# внутренний план разработки
agent-plan/

# .claude/ - НЕ игнорируем: промпты агентов в репо, заказчик их правит
data/research_cache.json
