# Шаблон .env для VPS DigitalOcean. Скопировать в /home/appuser/apps/liquidator/.env
# и заполнить значения. После заполнения: chmod 600 .env

# ================== Telegram ==================
# На этапе тестирования - ТЕСТОВЫЙ токен от @BotFather (liquidator_test_bot).
# В момент переключения подменить на боевой и `systemctl restart liquidator-bot`.
TG_BOT_TOKEN=

# Свой chat_id (от @userinfobot). Несколько - через запятую.
TG_ALLOWED_CHAT_IDS=

# ================== Claude Code ==================
# OAuth-токен от `claude setup-token` (локально на твоей машине).
CLAUDE_CODE_OAUTH_TOKEN=

# ================== Внешние API ==================
GROQ_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=articles
CLOUDINARY_WEB_TRANSFORMATION=f_auto,q_auto,w_1920
FAL_KEY=
FAL_MODEL=fal-ai/nano-banana-2
FAL_RESOLUTION=4K
FAL_ASPECT_RATIO=16:9
FAL_TIMEOUT_SEC=120
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_FOLDER_ID=
WORDSTAT_REGION_CODE=225
WORDSTAT_CACHE_TTL_DAYS=30
INDEXNOW_KEY=
INDEXNOW_HOST=pravo.shop
TEXTRU_USER_KEY=

# ================== Сайт (только для ссылок в TG, не для запуска сайта) ==================
PUBLIC_BASE_URL=https://pravo.shop
BOT_PREVIEW_TOKEN=

# ================== Watcher ==================
BOT_WATCH_INTERVAL=60
# КРИТИЧНО на VPS: уведомления только после реального git push.
REQUIRE_PUSHED_SENTINEL=true

# ================== Git push (HTTPS через PAT) ==================
GIT_PUSH_TOKEN=
GITHUB_REPO=serguess/liquidator
GITHUB_BRANCH=main
GIT_AUTHOR_NAME=Liquidator Scheduler
GIT_AUTHOR_EMAIL=scheduler@pravo.shop

# ================== Articles scheduler ==================
# ВАЖНО: на момент первого smoke-теста SCHEDULER_ENABLED не используется кодом
# напрямую (флаг был для FastAPI-lifespan на Cloud Apps). На VPS scheduler
# запускается через systemd timer, флаг здесь информационный.
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=144
SCHEDULER_TZ=Europe/Moscow
# 10 статей/день, ротация 3 физ / 3 юр / 3 взыск / 1 новость.
ARTICLES_PER_DAY=10
ROTATION_ORDER=fiz,yur,vzysk,fiz,yur,vzysk,fiz,yur,vzysk,news
ARTICLE_TIMEOUT_SEC=3600
